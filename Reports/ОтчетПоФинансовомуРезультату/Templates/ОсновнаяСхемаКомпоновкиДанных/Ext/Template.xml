;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	УчетЗатратОбороты.СтатьяЗатрат КАК СтатьяЗатрат,
	СУММА(УчетЗатратОбороты.СуммаОборот) КАК СуммаОборот
ПОМЕСТИТЬ ВременнаяТаблица_Расходы
ИЗ
	РегистрНакопления.УчетЗатрат.Обороты КАК УчетЗатратОбороты

СГРУППИРОВАТЬ ПО
	УчетЗатратОбороты.СтатьяЗатрат
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СУММА(ПродажиОбороты.СуммаОборот) КАК СуммаОборот,
	ВложенныйЗапрос.СтатьяЗатрат КАК СтатьяЗатрат
ПОМЕСТИТЬ ВременнаяТаблица_Доходы
ИЗ
	(ВЫБРАТЬ
		Номенклатура.Ссылка КАК Ссылка,
		Номенклатура.СтатьяЗатрат КАК СтатьяЗатрат
	ИЗ
		Справочник.Номенклатура КАК Номенклатура) КАК ВложенныйЗапрос
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты КАК ПродажиОбороты
		ПО ВложенныйЗапрос.Ссылка = ПродажиОбороты.Номенклатура

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.СтатьяЗатрат
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЕСТЬNULL(ВременнаяТаблица_Доходы.СуммаОборот, 0) КАК Доходы,
	ЕСТЬNULL(ВременнаяТаблица_Расходы.СуммаОборот, 0) КАК Расходы,
	ВременнаяТаблица_СтатьиЗатрат.СтатьяЗатрат КАК СтатьяЗатрат
ИЗ
	ВременнаяТаблица_СтатьиЗатрат КАК ВременнаяТаблица_СтатьиЗатрат
		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблица_Доходы КАК ВременнаяТаблица_Доходы
			ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблица_Расходы КАК ВременнаяТаблица_Расходы
			ПО ВременнаяТаблица_Доходы.СтатьяЗатрат = ВременнаяТаблица_Расходы.СтатьяЗатрат
		ПО ВременнаяТаблица_СтатьиЗатрат.СтатьяЗатрат = ВременнаяТаблица_Доходы.СтатьяЗатрат
ГДЕ
	ВременнаяТаблица_Доходы.СуммаОборот &lt;&gt; 0
	И ВременнаяТаблица_Расходы.СуммаОборот &lt;&gt; 0</query>
